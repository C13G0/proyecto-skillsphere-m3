# ============================================
# SkillSphere - Archivo de Configuración Ejemplo
# ============================================
# IMPORTANTE: Este archivo es un TEMPLATE.
# Debes crear un archivo .env en la raíz del proyecto con tus credenciales reales.
# NO COMITEES .env a Git - está excluido en .gitignore

# ============================================
# Configuración de PostgreSQL (Supabase Database)
# ============================================
# Conexión JDBC a PostgreSQL en Supabase
# Para obtener estos valores:
# 1. Ve a https://app.supabase.com
# 2. Selecciona tu proyecto
# 3. Ve a Settings > Database > Connection String
# 4. Copia los valores en los campos de abajo

DB_URL=jdbc:postgresql://ubafnnnjgedgueilqihx.supabase.co:5432/postgres
DB_USERNAME=postgres
DB_PASSWORD=tu-contraseña-postgres-aqui

# ============================================
# Configuración de Supabase REST API (Opcional)
# ============================================
# Reemplaza estos valores con tu proyecto y key de Supabase.
# Para obtener estos valores:
# 1. Ve a https://app.supabase.com
# 2. Selecciona tu proyecto
# 3. Ve a Settings > API
# 4. Copia tu Project URL en SUPABASE_URL
# 5. Copia tu service_role key (o public key) en SUPABASE_KEY

SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=tu-api-key-aqui

# ============================================
# Configuración Alternativa: PostgreSQL Directo (OPCIONAL)
# ============================================
# Si prefieres usar una base de datos PostgreSQL directa en lugar de Supabase REST,
# descomenta las siguientes líneas y comenta las de Supabase:

# DB_URL=jdbc:postgresql://localhost:5432/skillsphere_db
# DB_USERNAME=postgres
# DB_PASSWORD=tu_password_aqui
